# Copy this to .env in your project root and fill in your details

# VRChat Account Credentials
VRCHAT_EMAIL=your_vrchat_email@example.com
VRCHAT_PASSWORD=your_vrchat_password

# GenAI AI API Key for LLM
LLM_API_KEY=your_genai__api_key

# GenAI AI API Key for Vision (can be the same as LLM_API_KEY)
VISION_API_KEY=your_genai_api_key

# LM Studio Configuration (local LLM)
# Set to "true" to enable LM Studio instead of GenAI
LM_STUDIO_ENABLED=false
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_API_KEY=not-needed
LM_STUDIO_TEMPERATURE=0.7
LM_STUDIO_MAX_TOKENS=4096

# NEVER push your .env file to public repositories!
# Optional: Custom configurations can be modified in constants.py